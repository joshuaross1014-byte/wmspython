# Copy this file to ".env" in this folder and fill in real values.
# .env is git-ignored and must never be committed.

# --- Primary database (wms_connect.py) ---
DB_SERVER=your-db-host
DB_NAME=WMS
WMS_USER=your_login
WMS_PASS=your_password

# --- Second / cloud environment (cloud_connect.py) ---
CLOUD_DB_SERVER=your-cloud-db-host
CLOUD_DB_NAME=WMS

# --- Two-environment comparison (wms_compare.py) ---
WMS_SERVER=your-db-host
WMS_DB=WMS
WMS_OLD_LABEL=OLD (current)
WMS_NEW_SERVER=your-cloud-db-host
WMS_NEW_DB=WMS
WMS_NEW_USER=your_login
WMS_NEW_PASS=your_password
WMS_NEW_LABEL=NEW (migrated)

# --- Watcher safety flag (wms_watcher.py) ---
# 1 enables DML execution for files flagged accordingly; 0 = read-only.
WMS_ALLOW_DML=0
